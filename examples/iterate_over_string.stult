P : STD["IO"]["PRINT"]
CS : STD["TYPE"]["COLLECTION"]["SIZE"]

TEXT : "In the beginning was the word."

current_word : ""
word_count : 0

(( TEXT )) { ( CHAR )
	( CHAR = " " & @CS( @current_word ) ! 0 ) {
		@P(@current_word)
		@current_word : ""
		@word_count :+ 1
	},{
		@current_word :+ @CHAR
	}
}

( CS( current_word ) ! 0 ) {
	@P(@current_word)
	@word_count :+ 1
}

P("\n(Word count: ", word_count, ".)")