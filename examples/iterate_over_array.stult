P : STD["IO"]["PRINT"]
CS : STD["TYPE"]["COLLECTION"]["SIZE"]


DOG_NAMES : { "Rover", "Grover", "Groover", "Doofus" }

((DOG_NAMES)) { ( NAME, INDEX, COLLECTION )
	SIZE : @CS(COLLECTION)

	@P("Dog ", INDEX + 1, " (of ", SIZE, ") is called ", NAME, ".")
},{
	@P("And those are all the dogs I know.")
}