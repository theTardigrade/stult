PRINT : STD["IO"]["PRINT"]

multiline_array : {
    1
    2
    3
    4
    5
    6
    7
    8
}

singleline_array : { "test1", "test2", "test3" }

PRINT(multiline_array)
PRINT(singleline_array)

A : STD["TYPES"]["ARRAY"]["APPEND"]

another_array : {}

A(another_array, "example text", "and some more example text")

PRINT(another_array)

PRINT(STD["TYPES"]["COLLECTION"]["SIZE"](another_array))