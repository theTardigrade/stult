PRINT : STD["IO"]["PRINT"]

MULTILINE_ARRAY : {
    1
    2
    3
    4
    5
    6
    7
    8
}

SINGLELINE_ARRAY : { "test1", "test2", "test3" }

PRINT(MULTILINE_ARRAY)
PRINT(SINGLELINE_ARRAY)

APPEND_TO_ARRAY : STD["TYPE"]["ARRAY"]["APPEND"]

ANOTHER_ARRAY : {}

APPEND_TO_ARRAY(ANOTHER_ARRAY, "example text", "and some more example text")

PRINT(ANOTHER_ARRAY)

PRINT(STD["TYPE"]["COLLECTION"]["SIZE"](ANOTHER_ARRAY))