PRINT : STD["IO"]["PRINT"]

ITERATIONS : 10

i : ITERATIONS

((i > 0)) {
    @PRINT(@i) # Using the at symbol allows us to access a variable from outside the current scope

    @i :- 1
},{
	# code within this block runs just once when the conditional no longer holds true

    @PRINT("")
	@PRINT("THE COUNT IS OVER. PACK UP AND GO HOME.")
}