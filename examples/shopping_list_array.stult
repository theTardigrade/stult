##

EXAMPLE: shopping_list_array.stult

This code creates arrays, appends new values to a list and prints the updated
list size.

It demonstrates the use of multi-line array literals, single-line array literals,
standard-library array helpers and collection size checks.

##

WRITE_LINE : STD["IO"]["OUTPUT"]["WRITE_LINE"]
ARRAY : STD["TYPE"]["ARRAY"]
SIZE : STD["TYPE"]["COLLECTION"]["SIZE"]

SHOPPING_LIST : {
	"bread"
	"milk"
	"apples"
}

AISLES : { "bakery", "dairy", "grocery" }

WRITE_LINE("Shopping list before append: ", SHOPPING_LIST)
WRITE_LINE("Aisles: ", AISLES)

ARRAY["APPEND"](SHOPPING_LIST, "coffee", "rice")

WRITE_LINE("Shopping list after append: ", SHOPPING_LIST)
WRITE_LINE("Number of shopping list items: ", SIZE(SHOPPING_LIST))