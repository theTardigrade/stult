ASSERT : STD.ASSERT
FILE : STD.FILE
PATH : FILE.PATH
SIZE : STD.TYPE.COLLECTION.SIZE
IS_FOUND_IN : STD.TYPE.STRING.IS_FOUND_IN

ROOT : "stult_file_directory_helpers_tmp"
CHILD : PATH.JOIN(ROOT, "a.txt")
TEXT_CHILD : PATH.JOIN(ROOT, "unicode.txt")
BINARY_CHILD : PATH.JOIN(ROOT, "bytes.bin")
DEEP_PARENT : PATH.JOIN(ROOT, "deep")
DEEP_CHILD : PATH.JOIN(DEEP_PARENT, "leaf")

'{
	FILE.DELETE(DEEP_CHILD)
}|{ (_)
	_
}

'{
	FILE.DELETE(DEEP_PARENT)
}|{ (_)
	_
}

'{
	FILE.DELETE(CHILD)
}|{ (_)
	_
}

'{
	FILE.DELETE(TEXT_CHILD)
}|{ (_)
	_
}

'{
	FILE.DELETE(BINARY_CHILD)
}|{ (_)
	_
}

'{
	FILE.DELETE(ROOT)
}|{ (_)
	_
}

ASSERT.FALSE(FILE.EXISTS(ROOT), "temporary root should not exist before setup")
ASSERT.FALSE(FILE.IS_FILE(ROOT), "missing root should not be reported as a file")
ASSERT.FALSE(FILE.IS_DIR(ROOT), "missing root should not be reported as a directory")

ASSERT.EQUAL(FILE.MAKE_DIR(ROOT), _, "MAKE_DIR should return void when creating one directory")
ASSERT.TRUE(FILE.EXISTS(ROOT), "created root directory should exist")
ASSERT.TRUE(FILE.IS_DIR(ROOT), "created root should be reported as a directory")
ASSERT.FALSE(FILE.IS_FILE(ROOT), "created root directory should not be reported as a file")

FILE.WRITE(CHILD, "hello")
ASSERT.EQUAL(FILE.READ(CHILD), "hello", "WRITE without append flag should create and write file contents")
FILE.WRITE(CHILD, " world", +)
ASSERT.EQUAL(FILE.READ(CHILD), "hello world", "WRITE with append flag true should append contents")
FILE.WRITE(CHILD, "reset", -)
ASSERT.EQUAL(FILE.READ(CHILD), "reset", "WRITE with append flag false should overwrite contents")
FILE.WRITE(CHILD, "!", +)
ASSERT.EQUAL(FILE.READ(CHILD), "reset!", "WRITE with append flag true should append after overwrite")
ASSERT.TRUE(FILE.IS_FILE(CHILD), "written child path should be reported as a file")
ASSERT.FALSE(FILE.IS_DIR(CHILD), "written child path should not be reported as a directory")

FILE.WRITE(TEXT_CHILD, "café")
ASSERT.EQUAL(FILE.READ(TEXT_CHILD), "café", "READ without options should read the full text file")
ASSERT.EQUAL(FILE.READ(TEXT_CHILD, -), "café", "READ with useBytes false should read text")
ASSERT.EQUAL(FILE.READ(TEXT_CHILD, -, 1), "afé", "READ text mode offset should count Unicode code points")
ASSERT.EQUAL(FILE.READ(TEXT_CHILD, -, 3, 1), "é", "READ text mode range should not split multibyte characters")
ASSERT.EQUAL(FILE.READ(TEXT_CHILD, -, 4), "", "READ text mode offset at end should return an empty string")
ASSERT.EQUAL(FILE.READ(TEXT_CHILD, -, 0, 0), "", "READ text mode zero length should return an empty string")

FILE.WRITE(BINARY_CHILD, {0, 1, 2, 255})
FILE.WRITE(BINARY_CHILD, {3, 4}, +)
bytes : FILE.READ(BINARY_CHILD, +)
ASSERT.EQUAL(SIZE(bytes), 6, "READ byte mode should return every byte number")
ASSERT.EQUAL(bytes[0], 0, "READ byte mode should preserve zero byte")
ASSERT.EQUAL(bytes[3], 255, "READ byte mode should preserve byte 255")
ASSERT.EQUAL(bytes[5], 4, "WRITE byte-array append should append raw bytes")
byte_range : FILE.READ(BINARY_CHILD, +, 2, 3)
ASSERT.EQUAL(SIZE(byte_range), 3, "READ byte mode range should return requested byte count")
ASSERT.EQUAL(byte_range[0], 2, "READ byte mode range should start at byte offset")
ASSERT.EQUAL(byte_range[1], 255, "READ byte mode range should preserve invalid UTF-8 bytes")
ASSERT.EQUAL(byte_range[2], 3, "READ byte mode range should include following appended byte")
empty_byte_range : FILE.READ(BINARY_CHILD, +, 99)
ASSERT.EQUAL(SIZE(empty_byte_range), 0, "READ byte mode offset beyond end should return an empty array")

invalid_utf8_text_error : -
'{
	FILE.READ(BINARY_CHILD, -)
}|{ (error)
	@invalid_utf8_text_error : IS_FOUND_IN("valid UTF-8", error)
}
ASSERT.TRUE(invalid_utf8_text_error, "READ text mode should reject invalid UTF-8")

names : FILE.LIST(ROOT)
ASSERT.EQUAL(SIZE(names), 3, "LIST should return three entry names")
ASSERT.EQUAL(names[0], "a.txt", "LIST should sort entry names alphabetically")
ASSERT.EQUAL(names[1], "bytes.bin", "LIST should include byte file name")
ASSERT.EQUAL(names[2], "unicode.txt", "LIST should include unicode file name")

names_with_flag : FILE.LIST(ROOT, -)
ASSERT.EQUAL(SIZE(names_with_flag), 3, "LIST with absolute flag false should return entry names")
ASSERT.EQUAL(names_with_flag[0], "a.txt", "LIST with absolute flag false should sort names")

absolute_paths : FILE.LIST(ROOT, +)
ASSERT.EQUAL(SIZE(absolute_paths), 3, "LIST with absolute flag true should return three entry paths")
ASSERT.EQUAL(absolute_paths[0], PATH.ABS(CHILD), "LIST with absolute flag true should return the absolute child path")
ASSERT.EQUAL(absolute_paths[1], PATH.ABS(BINARY_CHILD), "LIST with absolute flag true should return the absolute byte file path")
ASSERT.EQUAL(absolute_paths[2], PATH.ABS(TEXT_CHILD), "LIST with absolute flag true should return the absolute unicode file path")

strict_nested_error : -
'{
	FILE.MAKE_DIR(DEEP_CHILD)
}|{ (_)
	@strict_nested_error : +
}
ASSERT.TRUE(strict_nested_error, "MAKE_DIR without recursive flag should fail when parent is missing")

ASSERT.EQUAL(FILE.MAKE_DIR(DEEP_CHILD, +), _, "MAKE_DIR with recursive flag true should create missing parents")
ASSERT.TRUE(FILE.IS_DIR(DEEP_CHILD), "recursive MAKE_DIR target should be reported as a directory")
ASSERT.EQUAL(FILE.MAKE_DIR(DEEP_CHILD, +), _, "recursive MAKE_DIR should succeed when the directory already exists")

strict_existing_error : -
'{
	FILE.MAKE_DIR(ROOT)
}|{ (_)
	@strict_existing_error : +
}
ASSERT.TRUE(strict_existing_error, "MAKE_DIR without recursive flag should fail when the directory already exists")

list_type_error : -
'{
	FILE.LIST(ROOT, "yes")
}|{ (error)
	@list_type_error : IS_FOUND_IN("expected a boolean", error)
}
ASSERT.TRUE(list_type_error, "LIST absolute flag should require a boolean")

make_dir_type_error : -
'{
	FILE.MAKE_DIR(ROOT, "yes")
}|{ (error)
	@make_dir_type_error : IS_FOUND_IN("expected a boolean", error)
}
ASSERT.TRUE(make_dir_type_error, "MAKE_DIR recursive flag should require a boolean")

write_append_type_error : -
'{
	FILE.WRITE(CHILD, "no", "yes")
}|{ (error)
	@write_append_type_error : IS_FOUND_IN("expected a boolean", error)
}
ASSERT.TRUE(write_append_type_error, "WRITE append flag should require a boolean")

write_byte_range_error : -
'{
	FILE.WRITE(BINARY_CHILD, {256})
}|{ (error)
	@write_byte_range_error : IS_FOUND_IN("0 to 255", error)
}
ASSERT.TRUE(write_byte_range_error, "WRITE byte-array content should reject values above 255")

write_byte_decimal_error : -
'{
	FILE.WRITE(BINARY_CHILD, {1.5})
}|{ (error)
	@write_byte_decimal_error : IS_FOUND_IN("whole number", error)
}
ASSERT.TRUE(write_byte_decimal_error, "WRITE byte-array content should reject decimal byte values")

read_mode_type_error : -
'{
	FILE.READ(CHILD, "bytes")
}|{ (error)
	@read_mode_type_error : IS_FOUND_IN("expected a boolean", error)
}
ASSERT.TRUE(read_mode_type_error, "READ useBytes flag should require a boolean")

read_offset_type_error : -
'{
	FILE.READ(CHILD, -, "one")
}|{ (error)
	@read_offset_type_error : IS_FOUND_IN("non-negative whole number", error)
}
ASSERT.TRUE(read_offset_type_error, "READ offset should require a non-negative whole number")

append_removed_error : -
'{
	FILE.APPEND(CHILD, "no")
}|{ (_)
	@append_removed_error : +
}
ASSERT.TRUE(append_removed_error, "STD.FILE.APPEND should no longer be available")

FILE.DELETE(DEEP_CHILD)
FILE.DELETE(DEEP_PARENT)
FILE.DELETE(CHILD)
FILE.DELETE(TEXT_CHILD)
FILE.DELETE(BINARY_CHILD)
FILE.DELETE(ROOT)
