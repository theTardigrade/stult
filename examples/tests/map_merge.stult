##

EXAMPLE: tests/map_merge.stult

This example checks STD.TYPE.MAP.MERGE.

MAP.MERGE(left, right) returns a new mutable shallow merge. The right map
overrides the left map. Input maps are not modified, frozen input maps are
accepted and entry values are reused rather than cloned.

Pass + as the optional third argument to deep-merge nested maps. Arrays,
strings and other values are replaced rather than merged.

##

ASSERT : STD.ERROR.ASSERT
COLLECTION : STD.TYPE.COLLECTION
FREEZE : COLLECTION.FREEZE
IS_FROZEN : COLLECTION.IS_FROZEN
MAP : STD.TYPE.MAP
TYPE : STD.TYPE

nested : {
	.value: 1
}

defaults : {
	.host: "localhost"
	.port: 3000
	.debug: -
	.nested: nested
	.NAME: "default"
}

user : {
	.port: 8080
	.debug: +
}

merged : MAP.MERGE(defaults, user)

ASSERT.EQUAL(merged.host, "localhost", "MERGE should keep entries that only exist in the left map")
ASSERT.EQUAL(merged.port, 8080, "MERGE should let the right map override the left map")
ASSERT.EQUAL(merged.debug, +, "overridden boolean entries should be kept")
ASSERT.EQUAL(merged.NAME, "default", "entries that are not overridden should be kept")

ASSERT.EQUAL(defaults.host, "localhost", "MERGE should not mutate the left input map")
ASSERT.EQUAL(defaults.port, 3000, "MERGE should not mutate overridden entries in the left input map")
ASSERT.EQUAL(user.port, 8080, "MERGE should not mutate the right input map")

ASSERT.FALSE(merged = defaults, "MERGE should return a new map, not the left input map")
ASSERT.FALSE(IS_FROZEN(merged), "MERGE should return a mutable map")

merged.extra : "added"
ASSERT.EQUAL(merged.extra, "added", "merged maps should allow new mutable entries")

merged.nested.value : 2
ASSERT.EQUAL(nested.value, 2, "shallow MERGE should reuse nested values rather than cloning them")

explicit_shallow : MAP.MERGE(defaults, user, -)
ASSERT.EQUAL(explicit_shallow.port, 8080, "MERGE with - should be an explicit shallow merge")
ASSERT.TRUE(explicit_shallow.nested = defaults.nested, "explicit shallow MERGE should reuse nested maps")

immutable_entry_failed : -
?{
	merged.NAME : "changed"
}|{
	@immutable_entry_failed : +
}
ASSERT.TRUE(immutable_entry_failed, "MERGE should preserve map-entry immutability")

frozen : FREEZE({
	.path: "/tmp"
})
from_frozen : MAP.MERGE(frozen, {:})
ASSERT.EQUAL(from_frozen.path, "/tmp", "MERGE should accept frozen input maps")
ASSERT.FALSE(IS_FROZEN(from_frozen), "MERGE should return a mutable map from frozen input maps")
from_frozen.path : "/var/tmp"
ASSERT.EQUAL(from_frozen.path, "/var/tmp", "MERGE result from frozen input should be mutable")
ASSERT.EQUAL(frozen.path, "/tmp", "MERGE should not mutate frozen input maps")

non_map_failed : -
?{
	MAP.MERGE(defaults, "not a map")
}|{
	@non_map_failed : +
}
ASSERT.TRUE(non_map_failed, "MERGE should reject non-map arguments")

bad_deep_flag_failed : -
?{
	MAP.MERGE(defaults, user, "deep")
}|{
	@bad_deep_flag_failed : +
}
ASSERT.TRUE(bad_deep_flag_failed, "MERGE should require the optional deep flag to be boolean")

wrong_arity_failed : -
?{
	MAP.MERGE(defaults)
}|{
	@wrong_arity_failed : +
}
ASSERT.TRUE(wrong_arity_failed, "MERGE should require two maps")

ASSERT.TRUE(TYPE.IS_MAP(merged), "MERGE should return a map")

base_config : {
	.server: {
		.host: "localhost"
		.port: 3000
	}

	.tags: {"base"}
	.cache: {
		.enabled: -
	}
}

user_config : {
	.server: {
		.port: 8080
		.NAME: "primary"
	}

	.tags: {"user"}
}

deep_merged : MAP.MERGE(base_config, user_config, +)

ASSERT.EQUAL(deep_merged.server.host, "localhost", "deep MERGE should keep nested entries from the left map")
ASSERT.EQUAL(deep_merged.server.port, 8080, "deep MERGE should override nested entries from the right map")
ASSERT.EQUAL(deep_merged.server.NAME, "primary", "deep MERGE should add nested entries from the right map")
ASSERT.EQUAL(deep_merged.tags[0], "user", "deep MERGE should replace arrays rather than merging them")
ASSERT.EQUAL(deep_merged.cache.enabled, -, "deep MERGE should keep non-overridden nested maps")

ASSERT.EQUAL(base_config.server.port, 3000, "deep MERGE should not mutate earlier nested maps")
ASSERT.EQUAL(user_config.server.port, 8080, "deep MERGE should not mutate later nested maps")
ASSERT.FALSE(deep_merged = base_config, "deep MERGE should return a new top-level map")
ASSERT.FALSE(deep_merged.server = base_config.server, "deep MERGE should create a new map when nested maps are merged")
ASSERT.FALSE(deep_merged.server = user_config.server, "deep MERGE nested result should not be either input map")
ASSERT.TRUE(deep_merged.cache = base_config.cache, "deep MERGE should reuse nested maps that are not recursively merged")
ASSERT.FALSE(IS_FROZEN(deep_merged), "deep MERGE should return a mutable map")
ASSERT.FALSE(IS_FROZEN(deep_merged.server), "deep MERGE should create mutable nested merge maps")

deep_merged.server.extra : "ok"
ASSERT.EQUAL(deep_merged.server.extra, "ok", "deep MERGE nested merge result should be mutable")
ASSERT.TRUE(TYPE.IS_ARRAY(deep_merged.tags), "deep MERGE should leave replacement arrays as arrays")

deep_immutable_entry_failed : -
?{
	deep_merged.server.NAME : "changed"
}|{
	@deep_immutable_entry_failed : +
}
ASSERT.TRUE(deep_immutable_entry_failed, "deep MERGE should preserve winning nested entry immutability")
