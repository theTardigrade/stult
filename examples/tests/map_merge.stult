##

EXAMPLE: tests/map_merge.stult

This example checks the standard map merge helpers.

MAP.MERGE_SHALLOW returns a new mutable map containing top-level entries from
one or more source maps. Later maps override earlier maps. Input maps are not
modified, frozen input maps are accepted, and entry values are reused rather
than cloned.

MAP.MERGE_DEEP follows the same left-to-right rules, but recursively merges map
values when both sides of the same key are maps. Arrays, strings and other
values are replaced rather than merged.

##

ASSERT : STD.ERROR.ASSERT
COLLECTION : STD.TYPE.COLLECTION
FREEZE : COLLECTION.FREEZE
IS_FROZEN : COLLECTION.IS_FROZEN
MAP : STD.TYPE.MAP
TYPE : STD.TYPE

nested : {
	.value: 1
}

defaults : {
	.host: "localhost"
	.port: 3000
	.debug: -
	.nested: nested
	.NAME: "default"
}

user : {
	.port: 8080
	.debug: +
}

overrides : {
	.host: "example.test"
}

merged : MAP.MERGE_SHALLOW(defaults, user, overrides)

ASSERT.EQUAL(merged.host, "example.test", "later maps should override earlier maps")
ASSERT.EQUAL(merged.port, 8080, "middle maps should override earlier maps")
ASSERT.EQUAL(merged.debug, +, "overridden boolean entries should be kept")
ASSERT.EQUAL(merged.NAME, "default", "entries that are not overridden should be kept")

ASSERT.EQUAL(defaults.host, "localhost", "MERGE_SHALLOW should not mutate the first input map")
ASSERT.EQUAL(defaults.port, 3000, "MERGE_SHALLOW should not mutate overridden entries in the first input map")
ASSERT.EQUAL(user.port, 8080, "MERGE_SHALLOW should not mutate later input maps")

ASSERT.FALSE(merged = defaults, "MERGE_SHALLOW should return a new map, not the first input map")
ASSERT.FALSE(IS_FROZEN(merged), "MERGE_SHALLOW should return a mutable map")

merged.extra : "added"
ASSERT.EQUAL(merged.extra, "added", "merged maps should allow new mutable entries")

merged.nested.value : 2
ASSERT.EQUAL(nested.value, 2, "MERGE_SHALLOW should reuse nested values rather than cloning them")

immutable_entry_failed : -
?{
	merged.NAME : "changed"
}|{
	@immutable_entry_failed : +
}
ASSERT.TRUE(immutable_entry_failed, "MERGE_SHALLOW should preserve map-entry immutability")

frozen : FREEZE({
	.path: "/tmp"
})
from_frozen : MAP.MERGE_SHALLOW(frozen)
ASSERT.EQUAL(from_frozen.path, "/tmp", "MERGE_SHALLOW should accept frozen input maps")
ASSERT.FALSE(IS_FROZEN(from_frozen), "MERGE_SHALLOW should return a mutable map from frozen input maps")
from_frozen.path : "/var/tmp"
ASSERT.EQUAL(from_frozen.path, "/var/tmp", "MERGE_SHALLOW result from frozen input should be mutable")
ASSERT.EQUAL(frozen.path, "/tmp", "MERGE_SHALLOW should not mutate frozen input maps")

non_map_failed : -
?{
	MAP.MERGE_SHALLOW(defaults, "not a map")
}|{
	@non_map_failed : +
}
ASSERT.TRUE(non_map_failed, "MERGE_SHALLOW should reject non-map arguments")

no_args_failed : -
?{
	MAP.MERGE_SHALLOW()
}|{
	@no_args_failed : +
}
ASSERT.TRUE(no_args_failed, "MERGE_SHALLOW should require at least one argument")

ASSERT.TRUE(TYPE.IS_MAP(merged), "MERGE_SHALLOW should return a map")

base_config : {
	.server: {
		.host: "localhost"
		.port: 3000
	}

	.tags: {"base"}
	.cache: {
		.enabled: -
	}
}

user_config : {
	.server: {
		.port: 8080
		.NAME: "primary"
	}

	.tags: {"user"}
}

deep_merged : MAP.MERGE_DEEP(base_config, user_config)

ASSERT.EQUAL(deep_merged.server.host, "localhost", "MERGE_DEEP should keep nested entries from earlier maps")
ASSERT.EQUAL(deep_merged.server.port, 8080, "MERGE_DEEP should override nested entries from later maps")
ASSERT.EQUAL(deep_merged.server.NAME, "primary", "MERGE_DEEP should add nested entries from later maps")
ASSERT.EQUAL(deep_merged.tags[0], "user", "MERGE_DEEP should replace arrays rather than merging them")
ASSERT.EQUAL(deep_merged.cache.enabled, -, "MERGE_DEEP should keep non-overridden nested maps")

ASSERT.EQUAL(base_config.server.port, 3000, "MERGE_DEEP should not mutate earlier nested maps")
ASSERT.EQUAL(user_config.server.port, 8080, "MERGE_DEEP should not mutate later nested maps")
ASSERT.FALSE(deep_merged = base_config, "MERGE_DEEP should return a new top-level map")
ASSERT.FALSE(deep_merged.server = base_config.server, "MERGE_DEEP should create a new map when nested maps are merged")
ASSERT.FALSE(deep_merged.server = user_config.server, "MERGE_DEEP nested merge result should not be either input map")
ASSERT.TRUE(deep_merged.cache = base_config.cache, "MERGE_DEEP should reuse nested maps that are not recursively merged")
ASSERT.FALSE(IS_FROZEN(deep_merged), "MERGE_DEEP should return a mutable map")
ASSERT.FALSE(IS_FROZEN(deep_merged.server), "MERGE_DEEP should create mutable nested merge maps")

deep_merged.server.extra : "ok"
ASSERT.EQUAL(deep_merged.server.extra, "ok", "MERGE_DEEP nested merge result should be mutable")
ASSERT.TRUE(TYPE.IS_ARRAY(deep_merged.tags), "MERGE_DEEP should leave replacement arrays as arrays")

deep_immutable_entry_failed : -
?{
	deep_merged.server.NAME : "changed"
}|{
	@deep_immutable_entry_failed : +
}
ASSERT.TRUE(deep_immutable_entry_failed, "MERGE_DEEP should preserve winning nested entry immutability")
