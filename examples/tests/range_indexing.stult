##

EXAMPLE: tests/range_indexing.stult

This example checks range indexing for number-indexed collections.

Range indexing uses the same inclusive/exclusive and positive-step range syntax
as array-literal ranges. It works for arrays and strings, not maps, and returns
a new mutable array or string.

##

WRITE_LINE : STD.IO.OUTPUT.WRITE_LINE

ASSERT : STD.ERROR.ASSERT
ASSERT_TRUE : ASSERT.TRUE
ASSERT_FALSE : ASSERT.FALSE
ASSERT_EQUAL : ASSERT.EQUAL

COLLECTION : STD.TYPE.COLLECTION
IS_FROZEN : COLLECTION.IS_FROZEN
STRING : STD.TYPE.STRING.NEW

text : "this is a test"
ASSERT_EQUAL(text[2..10:2], "i sat", "string range index should support inclusive stepped ranges")
ASSERT_EQUAL(text[2...10:2], "i sa", "string range index should support exclusive stepped ranges")
ASSERT_EQUAL(text[3..0], "siht", "string range index should support descending ranges")
ASSERT_EQUAL(text[1...1], "", "string range index should support empty ranges")
ASSERT_EQUAL(text [
	2..10:2
], "i sat", "multiline spaced string range index should work")

array : {1, 2, 3, 4, 5}
ASSERT_EQUAL(STRING(array[0...3]), "{1, 2, 3}", "array range index should support exclusive ranges")
ASSERT_EQUAL(STRING(array[0..3]), "{1, 2, 3, 4}", "array range index should support inclusive ranges")
ASSERT_EQUAL(STRING(array[4..2]), "{5, 4, 3}", "array range index should support descending ranges")
ASSERT_EQUAL(STRING(array[0..4:2]), "{1, 3, 5}", "array range index should support stepped ranges")
ASSERT_EQUAL(STRING(array[2...2]), "{}", "array range index should support empty ranges")
ASSERT_EQUAL(STRING(array [
	0...3
]), "{1, 2, 3}", "multiline spaced array range index should work")

frozen_array : ~{1, 2, 3}
frozen_array_slice : frozen_array[0...2]
ASSERT_FALSE(IS_FROZEN(frozen_array_slice), "array range index result should be mutable")
frozen_array_slice[0] : 99
ASSERT_EQUAL(STRING(frozen_array_slice), "{99, 2}", "array range index result should be mutable")

frozen_text : ~"abc"
frozen_text_slice : frozen_text[0...2]
ASSERT_FALSE(IS_FROZEN(frozen_text_slice), "string range index result should be mutable")
frozen_text_slice[0] : "A"
ASSERT_EQUAL(frozen_text_slice, "Ab", "string range index result should be mutable")

map : {
	.name : "Example"
}
map_range_failed : -
?{
	map[0...1]
}|{
	@map_range_failed : +
}
ASSERT_TRUE(map_range_failed, "map range index should fail")

array_out_of_bounds_failed : -
?{
	array[0..5]
}|{
	@array_out_of_bounds_failed : +
}
ASSERT_TRUE(array_out_of_bounds_failed, "array range indexes should be bounds checked")

string_out_of_bounds_failed : -
?{
	text[-1...-1]
}|{
	@string_out_of_bounds_failed : +
}
ASSERT_TRUE(string_out_of_bounds_failed, "empty string range index boundaries should be bounds checked")

bad_step_failed : -
?{
	array[0..4:0]
}|{
	@bad_step_failed : +
}
ASSERT_TRUE(bad_step_failed, "range index step should be positive")

WRITE_LINE("range indexing checks passed")
