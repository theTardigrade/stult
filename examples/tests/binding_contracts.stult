##

EXAMPLE: tests/binding_contracts.stult

This example checks optional runtime type contracts.

Stult is dynamic by default. A `<.>` contract records the runtime value kind of
the first assigned value and rejects later assignments of a different kind. A
`<*>` contract explicitly keeps the default dynamic behaviour. Named contracts
such as `STD.TYPE.NUMBER`, `STD.TYPE.ARRAY<...>` and `STD.TYPE.MAP<...>` opt in
to runtime enforcement for bindings and collection mutation.

##

ASSERT : STD.ERROR.ASSERT
IS_FOUND_IN : STD.TYPE.STRING.IS_FOUND_IN

count<.> : 0
count : 1
ASSERT.EQUAL(count, 1, "same-kind number reassignment should be valid")

value<*> : 0
value : "zero"
value : {:}
ASSERT.TRUE(STD.TYPE.IS_MAP(value), "explicit any contract should preserve dynamic assignment")

NAME<.> : "Example"
LIMIT<*> : 10
ASSERT.EQUAL(NAME, "Example", "immutable bindings may declare same-kind contracts")
ASSERT.EQUAL(LIMIT, 10, "immutable bindings may declare any contracts")

settings<STD.TYPE.MAP<STD.TYPE.NUMBER>> : {
	"key": 814
	"port": 8080
}

settings.key : 819
settings["timeout"] : 30
ASSERT.EQUAL(settings.key, 819, "map-wide value contracts should allow valid entry reassignment")
ASSERT.EQUAL(settings.timeout, 30, "map-wide value contracts should allow valid new entries")

value_error : ""
?{
	@count : "one"
}|{ (error)
	@value_error : error
}
ASSERT.TRUE(IS_FOUND_IN("expects number value, got string value", value_error), "same-kind binding should reject kind changes")

map_error : ""
?{
	settings.key : "820"
}|{ (error)
	@map_error : error
}
ASSERT.TRUE(IS_FOUND_IN("expects number value, got string value", map_error), "map-wide value contracts should reject invalid entries")

redeclaration_error : ""
?{
	local<.> : 1
	local<.> : 2
}|{ (error)
	@redeclaration_error : error
}
ASSERT.TRUE(IS_FOUND_IN("can only be declared when the binding is created", redeclaration_error), "same-kind contracts should not be redeclared on existing bindings")

number<STD.TYPE.NUMBER> : 11
number : 12
ASSERT.EQUAL(number, 12, "named number contract should allow number reassignment")

number_error : ""
?{
	@number : "twelve"
}|{ (error)
	@number_error : error
}
ASSERT.TRUE(IS_FOUND_IN("expects number value, got string value", number_error), "named number contract should reject string reassignment")

names<STD.TYPE.ARRAY<STD.TYPE.STRING>> : {"apple", "orange"}
names_alias : names
names_alias[2] : "pear"
ASSERT.EQUAL(names[2], "pear", "array string contract should allow string append through alias")

array_error : ""
?{
	names_alias[3] : 123
}|{ (error)
	@array_error : error
}
ASSERT.TRUE(IS_FOUND_IN("expects string value, got number value", array_error), "array string contract should reject non-string append through alias")

flags<STD.TYPE.MAP<STD.TYPE.BOOL>> : {
	"dev": -
	"prod": +
}
flags_alias : flags
flags_alias["test"] : +
ASSERT.EQUAL(flags.test, +, "map bool contract should allow bool entry through alias")

map_contract_error : ""
?{
	flags_alias["temp"] : "not available"
}|{ (error)
	@map_contract_error : error
}
ASSERT.TRUE(IS_FOUND_IN("expects bool value, got string value", map_contract_error), "map bool contract should reject non-bool entry through alias")

mixed_rows<STD.TYPE.ARRAY<STD.TYPE.ARRAY<*>>> : {
	{1, 2, 3}
	{"four", 5, 6}
	{_}
}
mixed_rows[0][0] : "one"
mixed_rows[3] : {+, "mixed", 99}
ASSERT.TRUE(STD.TYPE.IS_ARRAY(mixed_rows[3]), "nested any contracts should allow mixed inner values")

same_kind_values<STD.TYPE.MAP<.>> : {
	"a": 1
	"b": 2
	"c": 3
}
same_kind_values["d"] : 4

same_kind_map_error : ""
?{
	same_kind_values["e"] : "five"
}|{ (error)
	@same_kind_map_error : error
}
ASSERT.TRUE(IS_FOUND_IN("expects number value, got string value", same_kind_map_error), "nested same-kind map contracts should infer value kind")
