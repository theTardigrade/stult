##

EXAMPLE: tests/range_loop_optimization.stult

This example checks range materialisation and direct range-loop iteration for
ranges whose values are too large for Go int64.

The bytecode runtime can optimise direct single-range loop sources with zero,
one or two loop parameters without changing observable behaviour.

##

ASSERT : STD.ERROR.ASSERT
SIZE : STD.TYPE.COLLECTION.SIZE

START : 100000000000000000000
END : START + 2

materialised : {START..END}

ASSERT.EQUAL(SIZE(materialised), 3, "materialised big range should contain three values")
ASSERT.EQUAL(materialised[0], START, "materialised big range should keep the first value")
ASSERT.EQUAL(materialised[2], END, "materialised big range should keep the last value")

direct : {}

(({START..END})) { (value, position)
	direct[position] : value
}

ASSERT.EQUAL(SIZE(direct), 3, "direct big range loop should produce three values")
ASSERT.EQUAL(direct[0], START, "direct big range loop should produce the first value")
ASSERT.EQUAL(direct[2], END, "direct big range loop should produce the last value")

descending : {}

(({END..START})) { (value, position)
	descending[position] : value
}

ASSERT.EQUAL(descending[0], END, "direct big range loop should support descending ranges")
ASSERT.EQUAL(descending[2], START, "direct descending big range should end at the start value")

stepped : {}

(({START..(START + 10)[5]})) { (value, position)
	stepped[position] : value
}

ASSERT.EQUAL(SIZE(stepped), 3, "direct big range loop should support big stepped ranges")
ASSERT.EQUAL(stepped[0], START, "direct stepped big range should keep first value")
ASSERT.EQUAL(stepped[1], START + 5, "direct stepped big range should step by five")
ASSERT.EQUAL(stepped[2], START + 10, "direct stepped big range should keep final value")

collection_size : 0
collection_first : 0
collection_last : 0

(({START..END})) { (value, key, collection, position)
	(position = 0) {
		@collection_size : SIZE(collection)
		@collection_first : collection[0]
		@collection_last : collection[2]
	}
}

ASSERT.EQUAL(collection_size, 3, "range loop with collection parameter should materialise the array")
ASSERT.EQUAL(collection_first, START, "materialised collection should expose the first big value")
ASSERT.EQUAL(collection_last, END, "materialised collection should expose the last big value")
