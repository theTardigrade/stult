##

EXAMPLE: tests/array_starting_with_function_literal.stult

This example checks that arrays may contain function literals as their first
elements.

It protects the parser behaviour where brace literals beginning with "{ (" may
be parsed speculatively as function literals, while still allowing arrays to
contain function values.

The first array is multiline. The second array is single-line.

##

WRITE_LINE : STD["IO"]["OUTPUT"]["WRITE_LINE"]
STRING_NEW : STD["TYPE"]["STRING"]["NEW"]
SIZE : STD["TYPE"]["COLLECTION"]["SIZE"]

FUNCTIONS : {
	{ (A, B)
		(A + B)
	}
	{ (A, B)
		(A * B)
	}
}

INLINE_FUNCTIONS : {{ (A, B) (A - B) }, { (A, B) (A / B) }}

ADD : FUNCTIONS[0]
MULTIPLY : FUNCTIONS[1]
SUBTRACT : INLINE_FUNCTIONS[0]
DIVIDE : INLINE_FUNCTIONS[1]

WRITE_LINE("function count: " + STRING_NEW(SIZE(FUNCTIONS)))
WRITE_LINE("inline function count: " + STRING_NEW(SIZE(INLINE_FUNCTIONS)))
WRITE_LINE("add: " + STRING_NEW(ADD(8, 2)))
WRITE_LINE("multiply: " + STRING_NEW(MULTIPLY(8, 2)))
WRITE_LINE("subtract: " + STRING_NEW(SUBTRACT(8, 2)))
WRITE_LINE("divide: " + STRING_NEW(DIVIDE(8, 2)))