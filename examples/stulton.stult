##

EXAMPLE: stulton.stult

This code encodes a Stult map as STULTON text, checks whether the text is valid,
parses it back into a Stult value and then encodes it as text once again.

It demonstrates the use of STULTON data encoding, validation and parsing,
as well as Stult syntax for nested maps, arrays, booleans, numbers and strings.

##

WRITE_LINE : STD["IO"]["OUTPUT"]["WRITE_LINE"]
STULTON : STD["DATA"]["STULTON"]

TEXT_FROM_MAP : STULTON["NEW"]({
	"NAME": "example"
	"active": +
    "hobbies": {
        "carpetry"
        "carpentry"
        "woodwork"
        "marquetry"
        "fingerpainting"
    }
    "baggage": {
	    "empty_array": {}
	    "empty_map": {:}
    }
    "num": 8428535988035835038824.5835734
})

IS_TEXT_VALID : STULTON["IS_VALID"](TEXT_FROM_MAP)

WRITE_LINE("VALIDITY CHECK: ", IS_TEXT_VALID)

PARSED_TEXT : STULTON["PARSE"](TEXT_FROM_MAP)

WRITE_LINE()
WRITE_LINE(PARSED_TEXT)

PARSED_TEXT_REENCODED : STULTON["NEW"](PARSED_TEXT)

WRITE_LINE()
WRITE_LINE(PARSED_TEXT_REENCODED)
