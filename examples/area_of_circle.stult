PRINT : STD["IO"]["PRINT"]

MATH : STD["MATH"]
PI : MATH["PI"]
SQUARE : MATH["SQUARE"]

CIRCLE : {
	"radius": 10
	"AREA": { () R : CIRCLE["radius"] (@PI * @SQUARE(R)) }
}

PRINT("The area of the small circle:  ", CIRCLE["AREA"]())

CIRCLE["radius"] : 20

PRINT("The area of the big circle:    ", CIRCLE["AREA"]())