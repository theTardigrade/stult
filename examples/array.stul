PRINT : STD["IO"]["PRINT"]

multiline_array : {
    1
    2
    3
    4
    5
    6
    7
    8
}

singleline_array : { "test", "test2", "test3" }

PRINT(multiline_array)
PRINT(singleline_array)

A = STD["TYPES"]["ARRAY"]["APPEND"]

empty_collection : {}

A(empty_collection, "example text", "and some more example text")

PRINT(empty_collection)

PRINT(STD["TYPES"]["COLLECTION"]["SIZE"](multiline_array))